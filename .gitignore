# User-specific cluster config — NEVER commit. Copy gameservers.yml.example
# to gameservers.yml locally; the real file stays out of the repo so
# passwords, mod lists, and SteamIDs don't leak.
/group_vars/gameservers.yml

# User-specific ini overlays (see README "Bringing your own ini files")
/config/

